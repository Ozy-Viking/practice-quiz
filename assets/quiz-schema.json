{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "/quiz-schema.json",
	"title": "Practice Quiz",
	"description": "Schema for practice-quiz JSON files",
	"type": "object",
	"required": ["questions"],
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"title": {
			"type": "string",
			"description": "Display title for the quiz"
		},
		"config": {
			"$ref": "#/definitions/QuizConfig"
		},
		"marks_per_question": {
			"type": "number",
			"exclusiveMinimum": 0,
			"description": "Top-level shorthand; overrides config.marks_per_question"
		},
		"negative_marks": {
			"type": "boolean",
			"description": "Top-level shorthand; overrides config.allow_negative_mark"
		},
		"questions": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/definitions/QuizQuestion"
			}
		}
	},
	"definitions": {
		"QuizConfig": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"marks_per_question": {
					"type": "number",
					"exclusiveMinimum": 0,
					"default": 1.0,
					"description": "Score awarded for a fully correct answer"
				},
				"allow_negative_mark": {
					"type": "boolean",
					"default": false,
					"description": "Whether scores can go below zero (alias: negative_marks)"
				},
				"negative_marks": {
					"type": "boolean",
					"description": "Alias for allow_negative_mark"
				},
				"title": {
					"type": "string",
					"description": "Falls back to this if the top-level title is absent"
				},
				"description": {
					"type": "string"
				},
				"default_question_count": {
					"type": "integer",
					"minimum": 1,
					"description": "Pre-fill the question count input on the config screen"
				}
			}
		},
		"QuizQuestion": {
			"type": "object",
			"required": ["id", "question"],
			"additionalProperties": false,
			"description": "Must have at least one correct answer. No upper limit on total answers.",
			"properties": {
				"id": {
					"type": "string",
					"description": "Unique identifier for this question"
				},
				"question": {
					"type": "string",
					"description": "Question text displayed to the user"
				},
				"correct_answers": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"minItems": 1,
					"description": "One or more correct answer strings (alias: correctAnswers)"
				},
				"correctAnswers": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"minItems": 1,
					"description": "Alias for correct_answers"
				},
				"incorrect_answers": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Wrong answer strings (alias: incorrectAnswers)"
				},
				"incorrectAnswers": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Alias for incorrect_answers"
				},
				"explanation": {
					"type": "string",
					"description": "Explanation shown after submission (alias for metadata.explanation)"
				},
				"metadata": {
					"$ref": "#/definitions/QuestionMetadata",
					"description": "Study metadata (alias: hiddenInfo)"
				},
				"hiddenInfo": {
					"$ref": "#/definitions/QuestionMetadata",
					"description": "Alias for metadata"
				}
			},
			"oneOf": [
				{
					"required": ["correct_answers", "incorrect_answers"]
				},
				{
					"required": ["correct_answers", "incorrectAnswers"]
				},
				{
					"required": ["correctAnswers", "incorrect_answers"]
				},
				{
					"required": ["correctAnswers", "incorrectAnswers"]
				}
			]
		},
		"QuestionMetadata": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"study_location": {
					"type": "string",
					"description": "Where this topic was taught (e.g. 'Week 3'). Used by location filter."
				},
				"topic": {
					"type": "string",
					"description": "Subject area of the question. Used by topic filter."
				},
				"timestamp": {
					"type": "string",
					"description": "Timestamp or reference (shown in study info panel)"
				},
				"answer": {
					"type": "string",
					"description": "Original answer key reference (shown in study info panel)"
				},
				"explanation": {
					"type": "string",
					"description": "Explanation shown after submission"
				},
				"notes": {
					"type": "string",
					"description": "Additional study notes (shown if no explanation)"
				}
			}
		}
	}
}
